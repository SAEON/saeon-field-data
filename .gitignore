# =============================================================
# .gitignore
# Root level — applies to the entire monorepo
# =============================================================


# -------------------------------------------------------------
# Environment variables — never commit secrets
# -------------------------------------------------------------
.env
.env.local
.env.*.local


# -------------------------------------------------------------
# Node
# -------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# -------------------------------------------------------------
# Build outputs
# -------------------------------------------------------------
dist/
build/
.next/
**/dist/
**/dev-dist/


# -------------------------------------------------------------
# Raw uploaded files — live on the server, not in git
# -------------------------------------------------------------
raw_files/
uploads/


# -------------------------------------------------------------
# OS clutter
# -------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini


# -------------------------------------------------------------
# IDE
# -------------------------------------------------------------
.vscode/
.idea/
*.suo
*.user


# -------------------------------------------------------------
# Logs
# -------------------------------------------------------------
logs/
*.log


# -------------------------------------------------------------
# R data and test/reference files — not part of the codebase
# -------------------------------------------------------------
*.txt
**/*.txt
*.pdf
**/*.pdf
*.rda
*.dat
*.csv
